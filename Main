    speedAfterGrabEnabled = not speedAfterGrabEnabled
    checkmark.Visible = speedAfterGrabEnabled
    checkbox.BackgroundColor3 = speedAfterGrabEnabled
        and Color3.fromRGB(30, 60, 35)
        or  Color3.fromRGB(45, 45, 45)
    checkboxStroke.Color = speedAfterGrabEnabled
        and Color3.fromRGB(60, 220, 100)
        or  Color3.fromRGB(100, 100, 100)
end)

-- ── Base Box Creator ────────────────────────
local function createBaseBox(labelText, x, y, z, color)
    local existing = workspace:FindFirstChild(labelText .. "Box")
    if existing then existing:Destroy() end

    local box = Instance.new("Part")
    box.Name = labelText .. "Box"
    box.Size = Vector3.new(4, 4, 4)
    box.Position = Vector3.new(x, y, z)
    box.Anchored = true
    box.CanCollide = false
    box.BrickColor = color or BrickColor.new("Bright blue")
    box.Material = Enum.Material.Neon
    box.Transparency = 0.4
    box.Parent = workspace

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 160, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 3, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = box

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard

    return box
end

-- ── Equip Flying Carpet ─────────────────────
local function equipFlyingCarpet()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end

    local tool = player.Backpack:FindFirstChild("Flying Carpet")
    if tool then
        tool.Parent = char
    elseif char:FindFirstChild("Flying Carpet") then
        -- Already equipped
    else
        warn("Flying Carpet tool not found in backpack!")
    end
end

-- ── Teleport helper ─────────────────────────
local function tpTo(x, y, z)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    rootPart.CFrame = CFrame.new(x, y, z)
end

-- ── Post-grab sequence for Right ────────────
local function doRightPostGrabSequence()
    local autoPos = autoTPRightBox
        and (autoTPRightBox.Position + Vector3.new(0, 4, 0))
        or Vector3.new(-348.4, -3.0, 90.7)
    tpTo(autoPos.X, autoPos.Y, autoPos.Z)

    task.wait(0.5)

    local nextPos = nextTPAfterRightBox
        and (nextTPAfterRightBox.Position + Vector3.new(0, 4, 0))
        or Vector3.new(-348.3, -3.0, 76.5)
    tpTo(nextPos.X, nextPos.Y, nextPos.Z)
end

-- ── Post-grab sequence for Left ─────────────
local function doLeftPostGrabSequence()
    local autoPos = autoTPLeftBox
        and (autoTPLeftBox.Position + Vector3.new(0, 4, 0))
        or Vector3.new(-349.7, -3.0, 29.3)
    tpTo(autoPos.X, autoPos.Y, autoPos.Z)

    task.wait(0.3)

    local nextPos = nextTPAfterLeftBox
        and (nextTPAfterLeftBox.Position + Vector3.new(0, 4, 0))
        or Vector3.new(-349.7, -3.0, 18.3) -- 11 studs after on Z axis
    tpTo(nextPos.X, nextPos.Y, nextPos.Z)
end

-- ── Two-Stage TP ────────────────────────────
local function twoStageTP(midX, midY, midZ, finalPos, isRight)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Stage 1
    rootPart.CFrame = CFrame.new(midX, midY, midZ)

    task.wait(0.3)

    char = player.Character
    if not char then return end
    rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Stage 2
    rootPart.CFrame = CFrame.new(finalPos)

    equipFlyingCarpet()

    if isRight then
        startAutoGrab(function()
            doRightPostGrabSequence()
        end)
    else
        startAutoGrab(function()
            doLeftPostGrabSequence()
        end)
    end
end

-- ── Button Logic ────────────────────────────
rightBaseBtn.MouseButton1Click:Connect(function()
    rightBaseBox        = createBaseBox("RIGHT BASE",          -336.6, -5.1, 96.8, BrickColor.new("Bright blue"))
    autoTPRightBox      = createBaseBox("AUTO TP RIGHT",       -348.4, -7.0, 90.7, BrickColor.new("Bright orange"))
    nextTPAfterRightBox = createBaseBox("NEXT TP AFTER RIGHT", -348.3, -7.0, 76.5, BrickColor.new("Bright green"))
end)

leftBaseBtn.MouseButton1Click:Connect(function()
    leftBaseBox        = createBaseBox("LEFT BASE",           -336.8, -5.0, 24.3,  BrickColor.new("Bright blue"))
    autoTPLeftBox      = createBaseBox("AUTO TP LEFT",        -349.7, -7.0, 29.3,  BrickColor.new("Bright orange"))
    nextTPAfterLeftBox = createBaseBox("NEXT TP AFTER LEFT",  -349.7, -7.0, 45.7,  BrickColor.new("Bright green"))
end)

tpLeftBtn.MouseButton1Click:Connect(function()
    local finalPos
    if leftBaseBox then
        finalPos = leftBaseBox.Position + Vector3.new(0, 4, 0)
    else
        finalPos = Vector3.new(-336.8, -1.0, 24.3)
    end
    twoStageTP(-344.4, -7.0, 41.7, finalPos, false)
end)

tpRightBtn.MouseButton1Click:Connect(function()
    local finalPos
    if rightBaseBox then
        finalPos = rightBaseBox.Position + Vector3.new(0, 4, 0)
    else
        finalPos = Vector3.new(-336.6, -1.1, 96.8)
    end
    twoStageTP(-345.2, -7.0, 77.3, finalPos, true)
end)

-- Semi TP

local Players                = game:GetService("Players")
local ProximityPromptService = game:GetService("ProximityPromptService")
local player                 = Players.LocalPlayer

-- ── Proximity Prompt Logic ──────────────────
local function TriggerPrompt(prompt)
    if not prompt then return end
    if prompt.KeyboardKeyCode == Enum.KeyCode.F then return end
    pcall(function()
        prompt.HoldDuration = 0
        prompt:InputHoldBegin()
        task.wait(0.05)
        prompt:InputHoldEnd()
    end)
end

local autoGrabActive = false

local rightBaseBox        = nil
local leftBaseBox         = nil
local autoTPRightBox      = nil
local nextTPAfterRightBox = nil
local autoTPLeftBox       = nil
local nextTPAfterLeftBox  = nil

local speedAfterGrabEnabled = false

local function startAutoGrab(afterGrabCallback)
    autoGrabActive = true
    task.spawn(function()
        local grabbed = false
        while autoGrabActive do
            task.wait(0.1)
            local char = player.Character
            if char then
                local root = char:FindFirstChild("HumanoidRootPart")
                if root then
                    for _, obj in pairs(workspace:GetDescendants()) do
                        if not autoGrabActive then break end
                        if obj:IsA("ProximityPrompt") then
                            if obj.KeyboardKeyCode == Enum.KeyCode.F then continue end
                            local part = obj.Parent
                            while part and not part:IsA("BasePart") do
                                part = part.Parent
                            end
                            if part and part:IsA("BasePart") then
                                local dist = (part.Position - root.Position).Magnitude
                                if dist <= obj.MaxActivationDistance then
                                    TriggerPrompt(obj)
                                    if not grabbed then
                                        grabbed = true
                                        autoGrabActive = false
                                        if speedAfterGrabEnabled then
                                            local c = player.Character
                                            if c then
                                                local hum = c:FindFirstChildOfClass("Humanoid")
                                                if hum then
                                                    hum.WalkSpeed = 28
                                                end
                                            end
                                        end
                                        if afterGrabCallback then
                                            task.wait(0.3)
                                            afterGrabCallback()
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
            end
        end
    end)
end

local function stopAutoGrab()
    autoGrabActive = false
end

-- ── GUI Setup ───────────────────────────────

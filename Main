local function createButton(name, text, posY, bgColor)
    local btn = Instance.new("TextButton")
    btn.Name = name
    btn.Size = UDim2.new(1, -20, 0, 38)
    btn.Position = UDim2.new(0, 10, 0, posY)
    btn.BackgroundColor3 = bgColor or Color3.fromRGB(50, 50, 50)
    btn.BorderSizePixel = 0
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.TextSize = 14
    btn.Font = Enum.Font.GothamSemibold
    btn.AutoButtonColor = true
    btn.Parent = mainFrame

    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, 7)
    corner.Parent = btn

    local stroke = Instance.new("UIStroke")
    stroke.Color = Color3.fromRGB(100, 100, 100)
    stroke.Thickness = 1
    stroke.Parent = btn

    return btn
end

local rightBaseBtn = createButton("RightBaseBtn", "Right Base",  50,  Color3.fromRGB(60, 100, 180))
local leftBaseBtn  = createButton("LeftBaseBtn",  "Left Base",   98,  Color3.fromRGB(60, 100, 180))
local tpLeftBtn    = createButton("TPLeftBtn",    "TP to Left",  146, Color3.fromRGB(40, 140, 80))
local tpRightBtn   = createButton("TPRightBtn",   "TP to Right", 194, Color3.fromRGB(140, 60, 60))


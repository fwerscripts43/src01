-- ── Base Box Creator ────────────────────────
local function createBaseBox(labelText, x, y, z)
    local existing = workspace:FindFirstChild(labelText .. "Box")
    if existing then existing:Destroy() end

    local box = Instance.new("Part")
    box.Name = labelText .. "Box"
    box.Size = Vector3.new(6, 0.4, 6)
    box.CFrame = CFrame.new(x, y, z)
    box.Anchored = true
    box.CanCollide = false
    box.BrickColor = BrickColor.new("Really black")
    box.Material = Enum.Material.SmoothPlastic
    box.Transparency = 0
    box.Parent = workspace

    local selBox = Instance.new("SelectionBox")
    selBox.Adornee = box
    selBox.Color3 = Color3.fromRGB(255, 255, 255)
    selBox.LineThickness = 0.05
    selBox.SurfaceTransparency = 1
    selBox.Parent = box

    local billboard = Instance.new("BillboardGui")
    billboard.Size = UDim2.new(0, 180, 0, 40)
    billboard.StudsOffset = Vector3.new(0, 2, 0)
    billboard.AlwaysOnTop = true
    billboard.Parent = box

    local label = Instance.new("TextLabel")
    label.Size = UDim2.new(1, 0, 1, 0)
    label.BackgroundTransparency = 1
    label.Text = labelText
    label.TextColor3 = Color3.fromRGB(255, 255, 255)
    label.TextScaled = true
    label.Font = Enum.Font.GothamBold
    label.Parent = billboard

    return box
end

-- ── Equip Flying Carpet ─────────────────────
local function equipFlyingCarpet()
    local char = player.Character
    if not char then return end
    local humanoid = char:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    local tool = player.Backpack:FindFirstChild("Flying Carpet")
    if tool then
        tool.Parent = char
    elseif char:FindFirstChild("Flying Carpet") then
        -- Already equipped
    else
        warn("Flying Carpet tool not found in backpack!")
    end
end

-- ── Teleport helper ─────────────────────────
local function tpTo(x, y, z)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end
    rootPart.CFrame = CFrame.new(x, y, z)
end

-- ── Post-grab sequence for Right ────────────
local function doRightPostGrabSequence()
    local autoPos = autoTPRightBox
        and (autoTPRightBox.Position + Vector3.new(0, 3, 0))
        or Vector3.new(-348.4, -4.0, 90.7)
    tpTo(autoPos.X, autoPos.Y, autoPos.Z)

    task.wait(0.1)

    local nextPos = nextTPAfterRightBox
        and (nextTPAfterRightBox.Position + Vector3.new(0, 3, 0))
        or Vector3.new(-347.23, -3.58, 61.94)
    tpTo(nextPos.X, nextPos.Y, nextPos.Z)
end

-- ── Post-grab sequence for Left ─────────────
local function doLeftPostGrabSequence()
    local autoPos = autoTPLeftBox
        and (autoTPLeftBox.Position + Vector3.new(0, 3, 0))
        or Vector3.new(-349.7, -4.0, 29.3)
    tpTo(autoPos.X, autoPos.Y, autoPos.Z)

    task.wait(0.1)

    local nextPos = nextTPAfterLeftBox
        and (nextTPAfterLeftBox.Position + Vector3.new(0, 3, 0))
        or Vector3.new(-349.43, -3.58, 58.31)
    tpTo(nextPos.X, nextPos.Y, nextPos.Z)
end

-- ── Two-Stage TP ────────────────────────────
local function twoStageTP(midX, midY, midZ, finalPos, isRight)
    local char = player.Character
    if not char then return end
    local rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Stage 1
    rootPart.CFrame = CFrame.new(midX, midY, midZ)

    task.wait(0.1) -- quick

    char = player.Character
    if not char then return end
    rootPart = char:FindFirstChild("HumanoidRootPart")
    if not rootPart then return end

    -- Stage 2
    rootPart.CFrame = CFrame.new(finalPos)

    equipFlyingCarpet()

    if isRight then
        startAutoGrab(function()
            doRightPostGrabSequence()
        end)
    else
        startAutoGrab(function()
            doLeftPostGrabSequence()
        end)
    end
end


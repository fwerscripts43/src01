-- ── Snow Particles ──────────────────────────
local snowflakes = {}
local NUM_SNOW = 24

local function makeSnowflake()
    local lbl = Instance.new("TextLabel")
    lbl.BackgroundTransparency = 1
    lbl.Text = "❄"
    lbl.TextColor3 = Color3.fromRGB(255, 255, 255)
    lbl.TextTransparency = math.random(1, 4) / 10
    lbl.TextSize = math.random(8, 16)
    lbl.Font = Enum.Font.GothamBold
    lbl.Size = UDim2.new(0, 20, 0, 20)
    lbl.Position = UDim2.new(math.random(0, 180) / 200, 0, math.random(-30, 0) / 290, 0)
    lbl.ZIndex = 0
    lbl.Parent = mainFrame
    return {
        label = lbl,
        x     = math.random(0, 180) / 200,
        y     = math.random(-30, 0) / 290,
        speed = math.random(15, 40) / 1000,
        drift = math.random(-5, 5) / 2000,
    }
end

for i = 1, NUM_SNOW do
    local flake = makeSnowflake()
    flake.y = math.random(0, 290) / 290
    flake.label.Position = UDim2.new(flake.x, 0, flake.y, 0)
    snowflakes[i] = flake
end

RunService.Heartbeat:Connect(function(dt)
    for _, flake in ipairs(snowflakes) do
        flake.y = flake.y + flake.speed * dt * 60
        flake.x = flake.x + flake.drift * dt * 60
        if flake.y > 1.05 then
            flake.y = -0.08
            flake.x = math.random(0, 180) / 200
            flake.speed = math.random(15, 40) / 1000
            flake.drift = math.random(-5, 5) / 2000
        end
        if flake.x < 0 then flake.x = 0.9
        elseif flake.x > 0.95 then flake.x = 0 end
        flake.label.Position = UDim2.new(flake.x, 0, flake.y, 0)
    end
end)

